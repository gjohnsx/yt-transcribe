        return None
    return str(downloaded[0])


# ── Transcription ────────────────────────────────────────────────────────────

def format_ts(seconds):
    """Convert seconds to HH:MM:SS,mmm format (for JSON timestamps)."""
    ms = int(seconds * 1000)
    total_s = ms // 1000
    ms_rem = ms % 1000
    m, s = divmod(total_s, 60)
    h, m = divmod(m, 60)
    return f"{h:02d}:{m:02d}:{s:02d},{ms_rem:03d}"


def format_ts_short(seconds):
    """Convert seconds to HH:MM:SS format (for markdown headers)."""
    total_s = int(seconds)
    m, s = divmod(total_s, 60)
    h, m = divmod(m, 60)
    return f"{h:02d}:{m:02d}:{s:02d}"


def resolve_model_name(provider, model_name):
    """Select provider-specific default model when model is not explicitly set."""
    if provider == "elevenlabs" and model_name == DEFAULT_MODEL:
        return DEFAULT_ELEVENLABS_MODEL
    return model_name


def normalize_elevenlabs_language_code(language):
    """Map common 2-letter codes to ElevenLabs 3-letter language codes."""
    if not language:
        return None
    code = language.strip().lower()
    if "-" in code:
        code = code.split("-", 1)[0]
    if code in ("auto", "detect", "none", "null"):
        return None
    if len(code) == 3:
        return code
    return ELEVENLABS_LANGUAGE_MAP.get(code, code)


def to_plain_data(value):
    """Recursively convert SDK response objects into plain dict/list types."""
    if isinstance(value, dict):
        return {k: to_plain_data(v) for k, v in value.items()}
    if isinstance(value, list):
        return [to_plain_data(v) for v in value]
    if hasattr(value, "model_dump"):
        return to_plain_data(value.model_dump())
    if hasattr(value, "dict"):
        return to_plain_data(value.dict())
    if hasattr(value, "__dict__"):
        return to_plain_data(vars(value))
    return value


def split_csv_args(values):
    """Split repeated/CSV CLI args into a flat list of non-empty strings."""
    parsed = []
    for value in values or []:
        parts = [p.strip() for p in value.split(",")]
        parsed.extend(p for p in parts if p)
    return parsed


def normalize_elevenlabs_keyterms(keyterms):
    """Normalize keyterm list for ElevenLabs request."""
    parsed = split_csv_args(keyterms)
    if len(parsed) > 100:
        print(f"{RED}ElevenLabs keyterms limit is 100 entries.{RESET}", file=sys.stderr)
        sys.exit(1)
    for term in parsed:
        if len(term) > 50:
            print(
                f"{RED}Keyterm too long (max 50 chars):{RESET} {term[:80]}",
                file=sys.stderr,
            )
            sys.exit(1)
    return parsed or None


def normalize_elevenlabs_entity_detection(entity_detection):
    """Normalize entity_detection value to API-supported shapes."""
    parsed = split_csv_args(entity_detection)
    if not parsed:
        return None
    if len(parsed) == 1:
        return parsed[0]
    return parsed


def normalize_elevenlabs_additional_formats(formats):
    """Normalize additional export format request values."""
    parsed = split_csv_args(formats)
    if not parsed:
        return None
    return [{"format": fmt} for fmt in parsed]


def collect_entities_from_payload(payload):
    """Collect detected entities from single or multi-channel payloads."""
    entities = []
    top_level = payload.get("entities")
    if isinstance(top_level, list):
        entities.extend(top_level)

    transcripts = payload.get("transcripts")
    if isinstance(transcripts, list):
        for chunk in transcripts:
            if not isinstance(chunk, dict):
                continue
            chunk_entities = chunk.get("entities")
            if isinstance(chunk_entities, list):
                entities.extend(chunk_entities)

    return entities


def build_transcription_from_elevenlabs_words(
    words,
    fallback_text,
    default_speaker=None,
    channel_index=None,
):
    """Convert ElevenLabs word events into this CLI's segment structure."""
    transcription = []
    current = None

    def flush():
        nonlocal current
        if not current:
            return

        text = normalize_transcript_text("".join(current["text_parts"]))
        if text:
            from_ms = round(current["start_s"] * 1000)
            to_ms = round(current["end_s"] * 1000)
            seg = {
                "timestamps": {
                    "from": format_ts(current["start_s"]),
                    "to": format_ts(current["end_s"]),
                },
                "offsets": {
                    "from": from_ms,
                    "to": to_ms,
                },
                "text": text,
                "words": current["words"],
                "start_seconds": current["start_s"],
                "end_seconds": current["end_s"],
            }
            if current["speaker"]:
                seg["speaker"] = current["speaker"]
            if channel_index is not None:
                seg["channel_index"] = channel_index
            transcription.append(seg)

        current = None

    pause_split_s = 1.6
    for token in words:
        token_type = token.get("type", "word")
        token_text = token.get("text", "")
        token_speaker = token.get("speaker_id") or default_speaker

        token_start = token.get("start")
        token_end = token.get("end")
        token_start = float(token_start) if token_start is not None else None
        token_end = float(token_end) if token_end is not None else token_start

        if token_type == "audio_event":
            event = (token_text or "").strip()
            token_text = f"[{event}]" if event else ""

        if current is None and token_type == "spacing":
            continue

        if current and token_type != "spacing":
            speaker_changed = (
                current["speaker"] and token_speaker and current["speaker"] != token_speaker
            )
            long_pause = (
                token_start is not None
                and current["end_s"] is not None
                and (token_start - current["end_s"]) > pause_split_s
            )
            if speaker_changed or long_pause:
                flush()

        if current is None:
            start_s = token_start if token_start is not None else 0.0
            end_s = token_end if token_end is not None else start_s
            current = {
                "speaker": token_speaker,
                "start_s": start_s,
                "end_s": end_s,
                "text_parts": [],
                "words": [],
            }

        if current["speaker"] is None and token_speaker:
            current["speaker"] = token_speaker

        if token_text:
            current["text_parts"].append(token_text)

        if token_type == "word":
            clean_word = (token_text or "").strip()
            if clean_word and token_start is not None and token_end is not None:
                word = {
                    "word": clean_word,
                    "start": round(token_start * 1000),
                    "end": round(token_end * 1000),
                }
                if token_speaker:
                    word["speaker"] = token_speaker
                if channel_index is not None:
                    word["channel_index"] = channel_index
                current["words"].append(word)

        if token_end is not None:
            current["end_s"] = token_end

    flush()

    if transcription:
        return transcription

    text = normalize_transcript_text(fallback_text)
    if not text:
        return []

    fallback_seg = {
        "timestamps": {"from": format_ts(0), "to": format_ts(0)},
        "offsets": {"from": 0, "to": 0},
        "text": text,
        "words": [],
        "start_seconds": 0.0,
        "end_seconds": 0.0,
    }
    if default_speaker:
        fallback_seg["speaker"] = default_speaker
    if channel_index is not None:
        fallback_seg["channel_index"] = channel_index
    return [fallback_seg]


def speaker_segments_from_transcription(transcription):
    """Build diarization-like segments from speaker-labeled transcript segments."""
    speaker_segments = []
    for seg in transcription:
        speaker = seg.get("speaker")
        if not speaker:
            continue

        start_s = seg.get("start_seconds")
        end_s = seg.get("end_seconds")
        if start_s is None:
            start_s = seg.get("offsets", {}).get("from", 0) / 1000.0
        if end_s is None:
            end_s = seg.get("offsets", {}).get("to", 0) / 1000.0
        if end_s <= start_s:
            continue

        speaker_segments.append({
            "start": start_s,
            "end": end_s,
            "speaker": speaker,
        })

    return speaker_segments


def transcribe_faster_whisper(wav_path, model_name, language):
    """Transcribe audio with faster-whisper, returning the result dict."""
    from faster_whisper import WhisperModel

    print(f"\n{DIM}Loading model: {model_name}...{RESET}", file=sys.stderr)
    model = WhisperModel(model_name, device="auto", compute_type="auto")

    print(f"{DIM}Transcribing...{RESET}", file=sys.stderr)
    segments_gen, info = model.transcribe(
        wav_path,
        language=language,
        word_timestamps=True,
        vad_filter=True,
    )

    transcription = []

    for segment in segments_gen:
        from_ms = round(segment.start * 1000)
        to_ms = round(segment.end * 1000)

        words = []
        if segment.words:
            for w in segment.words:
                words.append({
                    "word": w.word.strip(),
                    "start": round(w.start * 1000),
                    "end": round(w.end * 1000),
                })

        transcription.append({
            "timestamps": {
                "from": format_ts(segment.start),
                "to": format_ts(segment.end),
            },
            "offsets": {
                "from": from_ms,
                "to": to_ms,
            },
            "text": segment.text,
            "words": words,
            # Temporary fields for markdown generation (cleaned before JSON save)
            "start_seconds": segment.start,
            "end_seconds": segment.end,
        })

        print(
            f"  [{format_ts(segment.start)} -> {format_ts(segment.end)}]{segment.text}",
            file=sys.stderr,
        )

    result = {
        "params": {
            "provider": "faster-whisper",
            "model": model_name,
            "language": language,
        },
        "result": {
            "language": info.language,
            "language_probability": info.language_probability,
            "duration": info.duration,
        },
        "transcription": transcription,
    }

    print(
        f"\n{GREEN}Transcribed {len(transcription)} segments{RESET}",
        file=sys.stderr,
    )

    return result


def transcribe_elevenlabs(
    audio_path,
    model_name,
    language,
    diarize_enabled=False,
    tag_audio_events=False,
    timestamps_granularity="word",
    keyterms=None,
    entity_detection=None,
    additional_formats=None,
    num_speakers=None,
    use_multi_channel=False,
    api_key=None,
):
    """Transcribe audio with ElevenLabs Speech-to-Text."""
    from elevenlabs.client import ElevenLabs

    key = api_key or os.environ.get("ELEVENLABS_API_KEY")
    if not key:
        print(f"{RED}ElevenLabs API key is required.{RESET}", file=sys.stderr)
        print(
            f"{DIM}Pass --elevenlabs-api-key or set ELEVENLABS_API_KEY env var.{RESET}",
            file=sys.stderr,
        )
        sys.exit(1)

    language_code = normalize_elevenlabs_language_code(language)
    print(f"\n{DIM}Calling ElevenLabs STT model: {model_name}...{RESET}", file=sys.stderr)
    client = ElevenLabs(api_key=key)

    request_kwargs = {
        "model_id": model_name,
        "tag_audio_events": tag_audio_events,
        "diarize": diarize_enabled,
        "timestamps_granularity": timestamps_granularity,
        "use_multi_channel": use_multi_channel,
    }
    if language_code:
        request_kwargs["language_code"] = language_code
    if keyterms:
        request_kwargs["keyterms"] = keyterms
    if entity_detection is not None:
        request_kwargs["entity_detection"] = entity_detection
    if additional_formats:
        request_kwargs["additional_formats"] = additional_formats
    if num_speakers is not None:
        request_kwargs["num_speakers"] = num_speakers

    with open(audio_path, "rb") as audio_file:
        response = client.speech_to_text.convert(file=audio_file, **request_kwargs)

    payload = to_plain_data(response)
    if not isinstance(payload, dict):
        print(
            f"{RED}Unexpected ElevenLabs response shape: {type(payload).__name__}{RESET}",
            file=sys.stderr,
        )
        sys.exit(1)
    transcription = []

    multichannel = payload.get("transcripts")
    if isinstance(multichannel, list):
        for chunk in multichannel:
            if not isinstance(chunk, dict):
                continue
            channel_idx = chunk.get("channel_index")
            speaker = f"channel_{channel_idx}" if channel_idx is not None else None
            transcription.extend(
                build_transcription_from_elevenlabs_words(
                    words=chunk.get("words") or [],
                    fallback_text=chunk.get("text", ""),
                    default_speaker=speaker,
                    channel_index=channel_idx,
                )
            )
        transcription.sort(key=lambda seg: seg.get("start_seconds", 0.0))
    else:
        transcription = build_transcription_from_elevenlabs_words(
            words=payload.get("words") or [],
            fallback_text=payload.get("text", ""),
        )

    for seg in transcription:
        print(
            f"  [{format_ts(seg['start_seconds'])} -> {format_ts(seg['end_seconds'])}] {seg['text']}",
            file=sys.stderr,
        )

    duration = max((seg.get("end_seconds", 0) for seg in transcription), default=0)
    entities = collect_entities_from_payload(payload)
    additional_formats_response = payload.get("additional_formats")
    if not additional_formats_response and isinstance(multichannel, list):
        per_channel_formats = []
        for chunk in multichannel:
            if not isinstance(chunk, dict):
                continue
            chunk_formats = chunk.get("additional_formats")
            if not chunk_formats:
                continue
            per_channel_formats.append({
                "channel_index": chunk.get("channel_index"),
                "additional_formats": chunk_formats,
            })
        additional_formats_response = per_channel_formats or None

    language_code = payload.get("language_code")
    language_probability = payload.get("language_probability")
    if not language_code and isinstance(multichannel, list) and multichannel:
        language_code = multichannel[0].get("language_code")
    if language_probability is None and isinstance(multichannel, list) and multichannel:
        language_probability = multichannel[0].get("language_probability")

    result = {
        "params": {
            "provider": "elevenlabs",
            "model": model_name,
            "language": language,
            "timestamps_granularity": timestamps_granularity,
            "tag_audio_events": tag_audio_events,
            "diarize": diarize_enabled,
            "use_multi_channel": use_multi_channel,
        },
        "result": {
            "language": language_code,
            "language_probability": language_probability,
            "duration": duration,
            "transcription_id": payload.get("transcription_id"),
            "entities": entities,
        },
        "transcription": transcription,
    }
    if additional_formats_response:
        result["result"]["additional_formats"] = additional_formats_response
    if keyterms:
        result["params"]["keyterms"] = keyterms
    if entity_detection is not None:
        result["params"]["entity_detection"] = entity_detection
    if additional_formats:
        result["params"]["additional_formats"] = additional_formats
    if num_speakers is not None:
        result["params"]["num_speakers"] = num_speakers

    print(
        f"\n{GREEN}Transcribed {len(transcription)} segments{RESET}",
        file=sys.stderr,
    )
    return result, payload


# ── Speaker diarization ──────────────────────────────────────────────────────

def diarize(wav_path, hf_token, num_speakers=None):
    """Run pyannote speaker diarization, return list of speaker segments."""
    import torch
    from pyannote.audio import Pipeline

    device = "mps" if torch.backends.mps.is_available() else "cpu"
    print(f"\n{DIM}Loading diarization model (device: {device})...{RESET}", file=sys.stderr)

    pipeline = Pipeline.from_pretrained(
        "pyannote/speaker-diarization-3.1",
        token=hf_token,
    )
    pipeline.to(torch.device(device))

    print(f"{DIM}Diarizing...{RESET}", file=sys.stderr)
    kwargs = {}
    if num_speakers is not None:
        kwargs["num_speakers"] = num_speakers

    result = pipeline(wav_path, **kwargs)

    # pyannote >= 3.1 returns DiarizeOutput with .speaker_diarization attribute
    annotation = result if hasattr(result, "itertracks") else result.speaker_diarization

    speaker_segments = []
    for turn, _, speaker in annotation.itertracks(yield_label=True):
        speaker_segments.append({
            "start": turn.start,
            "end": turn.end,
            "speaker": speaker,
        })

    # Count unique speakers
    speakers = set(s["speaker"] for s in speaker_segments)
    print(f"{GREEN}Found {len(speakers)} speakers{RESET}", file=sys.stderr)

    return speaker_segments


def assign_speakers(result, speaker_segments):
    """Assign speaker labels to transcript segments and words via max overlap."""
    def find_speaker(start_s, end_s):
        best_speaker = None
        best_overlap = 0.0
        for sp in speaker_segments:
            overlap_start = max(start_s, sp["start"])
            overlap_end = min(end_s, sp["end"])
            overlap = max(0.0, overlap_end - overlap_start)
            if overlap > best_overlap:
                best_overlap = overlap
                best_speaker = sp["speaker"]
        return best_speaker

    for seg in result["transcription"]:
        seg_start = seg["offsets"]["from"] / 1000.0
        seg_end = seg["offsets"]["to"] / 1000.0
        seg["speaker"] = find_speaker(seg_start, seg_end)

        for word in seg.get("words", []):
            word_start = word["start"] / 1000.0
            word_end = word["end"] / 1000.0
            word["speaker"] = find_speaker(word_start, word_end)

    return result


def find_speaker_timestamps(speaker_segments, max_samples=3):
    """Find up to max_samples representative timestamps per speaker.

    Picks midpoints of the longest speaking turns, sorted chronologically.
    Returns {speaker: [ts1, ts2, ...]}
    """
    from collections import defaultdict
    turns = defaultdict(list)
    for seg in speaker_segments:
        turns[seg["speaker"]].append((seg["end"] - seg["start"], seg["start"], seg["end"]))

    timestamps = {}
    for speaker, speaker_turns in turns.items():
        # Sort by duration descending, take top N
        top = sorted(speaker_turns, key=lambda t: t[0], reverse=True)[:max_samples]
        # Sort those chronologically by start time
        top.sort(key=lambda t: t[1])
        timestamps[speaker] = [(start + end) / 2.0 for _, start, end in top]

    return timestamps


def extract_speaker_frames(video_path, speaker_timestamps, tmp_dir):
    """Extract sample frames for each speaker and tile into a horizontal strip.

    Returns {speaker: (composite_image_path, [timestamps])}
    """
    frames = {}
    for speaker, ts_list in speaker_timestamps.items():
        # Extract individual frames
        individual = []
        for i, ts in enumerate(ts_list):
            frame_path = str(Path(tmp_dir) / f"frame_{speaker}_{i}.png")
            r = subprocess.run(
                [
                    "ffmpeg", "-y",
                    "-ss", f"{ts:.3f}",
                    "-i", video_path,
                    "-frames:v", "1",
                    "-vf", "scale=320:-1",
                    frame_path,
                    "-loglevel", "error",
                ],
                capture_output=True, text=True,
            )
            if r.returncode == 0 and Path(frame_path).exists():
                individual.append(frame_path)

        if not individual:
            print(f"  {DIM}Could not extract frames for {speaker}{RESET}", file=sys.stderr)
            continue

        # Tile into horizontal strip if multiple frames
        if len(individual) == 1:
            frames[speaker] = (individual[0], ts_list)
        else:
            composite = str(Path(tmp_dir) / f"strip_{speaker}.png")
            inputs = []
            for p in individual:
                inputs.extend(["-i", p])
            r = subprocess.run(
                [
                    "ffmpeg", "-y", *inputs,
                    "-filter_complex", f"hstack=inputs={len(individual)}",
                    composite,
                    "-loglevel", "error",
                ],
                capture_output=True, text=True,
            )
            if r.returncode == 0 and Path(composite).exists():
                frames[speaker] = (composite, ts_list)
            else:
                # Fallback to first frame if tiling fails
                frames[speaker] = (individual[0], ts_list)

    return frames


def rename_speakers(result, name_map):
    """Replace generic SPEAKER_XX labels with user-provided names."""
    if not name_map:
        return result
    for seg in result["transcription"]:
        if seg.get("speaker") in name_map:
            seg["speaker"] = name_map[seg["speaker"]]
        for word in seg.get("words", []):
            if word.get("speaker") in name_map:
                word["speaker"] = name_map[word["speaker"]]
    return result


# ── Interactive speaker identification ────────────────────────────────────────

def supports_kitty_graphics():
    """Check if terminal supports Kitty graphics protocol."""
    term = os.environ.get("TERM_PROGRAM", "").lower()
    return term in ("ghostty", "kitty", "wezterm")


def display_image_kitty(image_path):
    """Display a PNG image inline using the Kitty graphics protocol."""
    with open(image_path, "rb") as f:
        encoded = base64.standard_b64encode(f.read())

    chunk_size = 4096
    w = sys.stdout.buffer.write
    for i in range(0, len(encoded), chunk_size):
        chunk = encoded[i:i + chunk_size]
        is_last = i + chunk_size >= len(encoded)
        if i == 0:
            w(f"\x1b_Ga=T,f=100,m={0 if is_last else 1};".encode("ascii"))
        else:
            w(f"\x1b_Gm={0 if is_last else 1};".encode("ascii"))
        w(chunk)
        w(b"\x1b\\")
    sys.stdout.buffer.flush()
    print("", file=sys.stderr)


def display_image_fallback(image_path):
    """Open image in macOS Preview as a fallback."""
    subprocess.run(["open", image_path], check=False)
    print(f"  {DIM}(Opened in Preview){RESET}", file=sys.stderr)


def find_sample_text(speaker, result):
    """Find a short sample transcript line for a speaker."""
    for seg in result["transcription"]:
        if seg.get("speaker") == speaker:
            text = seg["text"].strip()
            if len(text) > 80:
                text = text[:77] + "..."
            return text
    return None


def make_hyperlink(url, text):
    """Create an OSC 8 clickable hyperlink for terminal display."""
    return f"\x1b]8;;{url}\x1b\\{text}\x1b]8;;\x1b\\"


def prompt_speaker_names(speaker_segments, frames, result, video_url=None, time_offset=0.0):
    """Display speaker frames with timestamps and prompt user for names."""
    seen = set()
    speakers_ordered = []
    for seg in speaker_segments:
        if seg["speaker"] not in seen:
            seen.add(seg["speaker"])
            speakers_ordered.append(seg["speaker"])

    use_kitty = supports_kitty_graphics()
    name_map = {}

    print(f"\n{BOLD}Speaker Identification{RESET}", file=sys.stderr)
    print(f"{DIM}Type a name for each speaker (Enter to keep default){RESET}\n", file=sys.stderr)

    for speaker in speakers_ordered:
        print(f"  {CYAN}{speaker}{RESET}", file=sys.stderr)

        if speaker in frames:
            image_path, ts_list = frames[speaker]
            # Show timestamps as clickable YouTube links
            if video_url:
                ts_links = []
                for t in ts_list:
                    absolute_t = t + (time_offset or 0.0)
                    label = format_ts_short(absolute_t)
                    yt_url = (
                        f"{video_url}&t={int(absolute_t)}s"
                        if "?" in video_url
                        else f"{video_url}?t={int(absolute_t)}s"
                    )
                    ts_links.append(make_hyperlink(yt_url, label))
                print(f"  {DIM}Samples at: {', '.join(ts_links)}{RESET}", file=sys.stderr)
            else:
                ts_strs = [format_ts_short(t) for t in ts_list]
                print(f"  {DIM}Samples at: {', '.join(ts_strs)}{RESET}", file=sys.stderr)

            if use_kitty:
                display_image_kitty(image_path)
            else:
                display_image_fallback(image_path)
        else:
            print(f"  {DIM}(no frame available){RESET}", file=sys.stderr)

        # Show a sample transcript line
        sample = find_sample_text(speaker, result)
        if sample:
            print(f"  {DIM}\"{sample}\"{RESET}", file=sys.stderr)

        try:
            name = input(f"  Name for {speaker} [Enter to skip]: ").strip()
        except (EOFError, KeyboardInterrupt):
            print(f"\n{DIM}Skipping remaining speakers{RESET}", file=sys.stderr)
            break

        if name:
            name_map[speaker] = name
            print(f"  {GREEN}{speaker} -> {name}{RESET}\n", file=sys.stderr)
        else:
            print(f"  {DIM}Keeping {speaker}{RESET}\n", file=sys.stderr)

    return name_map


# ── Output helpers ───────────────────────────────────────────────────────────

def resolve_output_dir(args):
    """Determine the output directory from CLI args."""
    if args.output:
        return Path(args.output)
    if args.no_vault:
        return Path.cwd()
    return VAULT_ROOT / args.vault_dir


def sanitize_filename(title):
    """Strip unsafe characters from a filename and limit length."""
    # Remove characters that are problematic in filenames
    cleaned = re.sub(r'[<>:"/\\|?*]', "", title)
    # Collapse whitespace
    cleaned = re.sub(r"\s+", " ", cleaned).strip()
    # Limit length
    if len(cleaned) > 200:
        cleaned = cleaned[:200].rstrip()
    return cleaned


# ── Obsidian Markdown generation ─────────────────────────────────────────────

def normalize_transcript_text(text):
    """Normalize transcript spacing to keep markdown paragraphs clean."""
    return re.sub(r"\s+", " ", text or "").strip()


def split_paragraphs(text, target_chars=420, max_chars=620):
    """Split text into readable paragraph chunks around sentence boundaries."""
    text = normalize_transcript_text(text)
    if not text:
        return []

    sentences = [s.strip() for s in re.split(r"(?<=[.!?])\s+", text) if s.strip()]
    if not sentences:
        return [text]

    paragraphs = []
    current = []
    current_len = 0

    def flush_current():
        nonlocal current, current_len
        if current:
            paragraphs.append(" ".join(current))
            current = []
            current_len = 0

    for sentence in sentences:
        if len(sentence) > max_chars:
            flush_current()
            words = sentence.split()
            chunk = []
            chunk_len = 0
            for word in words:
                addition = len(word) if not chunk else len(word) + 1
                if chunk and chunk_len + addition > max_chars:
                    paragraphs.append(" ".join(chunk))
                    chunk = [word]
                    chunk_len = len(word)
                else:
                    chunk.append(word)
                    chunk_len += addition
            if chunk:
                paragraphs.append(" ".join(chunk))
            continue

        addition = len(sentence) if not current else len(sentence) + 1
        if current and current_len + addition > target_chars:
            flush_current()
        current.append(sentence)
        current_len += addition

    flush_current()
    return paragraphs


def build_transcript_blocks(transcription, merge_gap_s=1.6):
    """Merge adjacent same-speaker segments into larger blocks."""
    blocks = []
    for seg in transcription:
        text = normalize_transcript_text(seg.get("text", ""))
        if not text:
            continue

        start = seg.get("start_seconds")
        end = seg.get("end_seconds")
        if start is None:
            start = seg["offsets"]["from"] / 1000.0
        if end is None:
            end = seg["offsets"]["to"] / 1000.0

        speaker = seg.get("speaker")
        if blocks:
            prev = blocks[-1]
            gap = start - prev["end"]
            if prev["speaker"] == speaker and gap <= merge_gap_s:
                prev["text"] = f"{prev['text']} {text}"
                prev["end"] = end
                continue

        blocks.append({
            "speaker": speaker,
            "start": start,
            "end": end,
            "text": text,
        })

    return blocks


def yaml_quote(value):
    """Return a double-quoted YAML-safe scalar."""
    return json.dumps("" if value is None else str(value), ensure_ascii=False)


def generate_markdown(meta, result, model_name):
    """Build an Obsidian-compatible Markdown document from transcript data."""
    lines = []
    params = result.get("params", {})
    result_meta = result.get("result", {})
    entities = result_meta.get("entities") or []

    # YAML frontmatter
    lines.append("---")
    lines.append(f"title: {yaml_quote(meta['title'])}")
    lines.append(f"url: {meta['url']}")
    lines.append(f"channel: {yaml_quote(meta['channel'])}")
    lines.append(f"date: {meta['date']}")
    lines.append(f"duration: {meta['duration_str']}")
    lines.append(f"model: {yaml_quote(model_name)}")
    if params.get("provider"):
        lines.append(f"provider: {yaml_quote(params.get('provider'))}")
    if params.get("clip_start_seconds") is not None:
        lines.append(f"clip_start_seconds: {format_seconds_for_yt_dlp(params['clip_start_seconds'])}")
    if params.get("clip_end_seconds") is not None:
        lines.append(f"clip_end_seconds: {format_seconds_for_yt_dlp(params['clip_end_seconds'])}")
    if params.get("clip_start_seconds") is not None and params.get("clip_end_seconds") is not None:
        clip_duration = max(0.0, params["clip_end_seconds"] - params["clip_start_seconds"])
        lines.append(f"clip_duration_seconds: {format_seconds_for_yt_dlp(clip_duration)}")
    if result_meta.get("transcription_id"):
        lines.append(f"transcription_id: {yaml_quote(result_meta.get('transcription_id'))}")
    lines.append(f"entity_count: {len(entities)}")
    if entities:
        lines.append("entities:")
        for entity in entities:
            if not isinstance(entity, dict):
                continue
            text = yaml_quote(entity.get("text", ""))
            entity_type = yaml_quote(entity.get("entity_type", "unknown"))
            start_char = entity.get("start_char", 0)
            end_char = entity.get("end_char", 0)
            lines.append(f"  - text: {text}")
            lines.append(f"    type: {entity_type}")
            lines.append(f"    start_char: {start_char}")
            lines.append(f"    end_char: {end_char}")
    lines.append("tags:")
    lines.append("  - transcript")
    lines.append("  - youtube")
    lines.append("---")
    lines.append("")

    # Title
    lines.append(f"# {meta['title']}")
    lines.append("")

    transcription = result["transcription"]
    if not transcription:
        lines.append("_No transcript segments generated._")
        lines.append("")
        return "\n".join(lines)

    blocks = build_transcript_blocks(transcription)
    if not blocks:
        lines.append("_No transcript text generated._")
        lines.append("")
        return "\n".join(lines)

    speakers = [b["speaker"] for b in blocks if b.get("speaker")]
    unique_speakers = list(dict.fromkeys(speakers))
    single_speaker_mode = len(unique_speakers) <= 1

    lines.append(
        f"_Transcript span: {format_ts_short(blocks[0]['start'])} - {format_ts_short(blocks[-1]['end'])}. "
        "Word-level timestamps are in the companion JSON._"
    )
    lines.append("")

    if entities:
        lines.append("## Detected Entities")
        lines.append("")
        for entity in entities:
            if not isinstance(entity, dict):
                continue
            lines.append(
                f"- {entity.get('entity_type', 'unknown')}: "
                f"\"{entity.get('text', '').strip()}\" "
                f"(chars {entity.get('start_char', 0)}-{entity.get('end_char', 0)})"
            )
        lines.append("")

    lines.append("## Transcript")
    lines.append("")

    if single_speaker_mode:
        speaker = unique_speakers[0] if unique_speakers else None
        if speaker:
            lines.append(f"### {speaker}")
            lines.append("")

        for block in blocks:
            for paragraph in split_paragraphs(block["text"]):
                lines.append(paragraph)
                lines.append("")
    else:
        prev_speaker = None
        for block in blocks:
            speaker = block.get("speaker") or "Unknown Speaker"
            if speaker != prev_speaker:
                lines.append(f"### {speaker}")
                lines.append("")
                prev_speaker = speaker

            lines.append(f"_{format_ts_short(block['start'])} - {format_ts_short(block['end'])}_")
            lines.append("")

            for paragraph in split_paragraphs(block["text"]):
                lines.append(paragraph)
                lines.append("")

    return "\n".join(lines)


# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    args = parse_args()
    model_name = resolve_model_name(args.provider, args.model)
    check_deps(args.provider, diarize_enabled=args.diarize or args.name_speakers)
    print(f"{BOLD}{CYAN}yt-transcribe{RESET}", file=sys.stderr)
    print(f"{DIM}Provider: {args.provider} | Model: {model_name}{RESET}", file=sys.stderr)
    if args.start is not None or args.end is not None:
        clip_start = format_ts_short(args.start or 0.0)
        clip_end = format_ts_short(args.end) if args.end is not None else "end"
        print(f"{DIM}Clip: {clip_start} -> {clip_end}{RESET}", file=sys.stderr)

    elevenlabs_api_key = args.elevenlabs_api_key or os.environ.get("ELEVENLABS_API_KEY")
    if args.provider == "elevenlabs" and not elevenlabs_api_key:
        print(f"{RED}ElevenLabs API key is required for --provider elevenlabs.{RESET}", file=sys.stderr)
        print(
            f"{DIM}Pass --elevenlabs-api-key or set ELEVENLABS_API_KEY env var.{RESET}",
            file=sys.stderr,
        )
        sys.exit(1)

    meta = fetch_metadata(args.url)

    output_dir = resolve_output_dir(args)
    output_dir.mkdir(parents=True, exist_ok=True)
    base_name = sanitize_filename(meta["title"])

    # --name-speakers implies --diarize
    if args.name_speakers:
        args.diarize = True

    # Resolve HF token for diarization
    hf_token = None
    if args.diarize and args.provider == "faster-whisper":
        hf_token = args.hf_token or os.environ.get("HF_TOKEN")
        if not hf_token:
            print(f"{RED}Diarization requires a HuggingFace token.{RESET}", file=sys.stderr)
            print(f"{DIM}Pass --hf-token TOKEN or set HF_TOKEN env var.{RESET}", file=sys.stderr)
            print(f"{DIM}Get one at: https://huggingface.co/settings/tokens{RESET}", file=sys.stderr)
            sys.exit(1)

    tmp_dir = tempfile.mkdtemp(prefix="yt_transcribe_")
    raw_provider_payload = None
    try:
        source_audio_path = download_audio(
            args.url,
            tmp_dir,
            start_seconds=args.start,
            end_seconds=args.end,
        )

        speaker_segments = None
        if args.provider == "elevenlabs":
            keyterms = normalize_elevenlabs_keyterms(args.keyterm)
            entity_detection = normalize_elevenlabs_entity_detection(args.entity_detection)
            additional_formats = normalize_elevenlabs_additional_formats(args.additional_format)
            result, raw_provider_payload = transcribe_elevenlabs(
                audio_path=source_audio_path,
                model_name=model_name,
                language=args.language,
                diarize_enabled=args.diarize,
                tag_audio_events=args.tag_audio_events,
                timestamps_granularity=args.timestamps_granularity,
                keyterms=keyterms,
                entity_detection=entity_detection,
                additional_formats=additional_formats,
                num_speakers=args.speakers,
                use_multi_channel=args.use_multi_channel,
                api_key=elevenlabs_api_key,
            )
            if args.diarize:
                speaker_segments = speaker_segments_from_transcription(result["transcription"])
        else:
            wav_path = convert_audio_for_faster_whisper(source_audio_path, tmp_dir)
            result = transcribe_faster_whisper(wav_path, model_name, args.language)
            if args.diarize:
                speaker_segments = diarize(wav_path, hf_token, args.speakers)
                result = assign_speakers(result, speaker_segments)

        if args.name_speakers and speaker_segments and sys.stdin.isatty():
            video_path = download_video(
                args.url,
                tmp_dir,
                start_seconds=args.start,
                end_seconds=args.end,
            )
            if video_path:
                timestamps = find_speaker_timestamps(speaker_segments)
                frames = extract_speaker_frames(video_path, timestamps, tmp_dir)
                if frames:
                    name_map = prompt_speaker_names(
                        speaker_segments,
                        frames,
                        result,
                        video_url=args.url,
                        time_offset=(args.start or 0.0),
                    )
                    if name_map:
                        result = rename_speakers(result, name_map)
                else:
                    print(f"{DIM}Could not extract speaker frames, skipping naming{RESET}", file=sys.stderr)
            else:
                print(f"{DIM}Could not download video, skipping speaker naming{RESET}", file=sys.stderr)
    finally:
        shutil.rmtree(tmp_dir, ignore_errors=True)

    if args.start is not None or args.end is not None:
        result["params"]["clip_start_seconds"] = args.start if args.start is not None else 0.0
        if args.end is not None:
            result["params"]["clip_end_seconds"] = args.end

    # Generate markdown (needs start_seconds/end_seconds)
    md_content = generate_markdown(meta, result, model_name)

    # Clean internal fields before saving JSON
    for seg in result["transcription"]:
        seg.pop("start_seconds", None)
        seg.pop("end_seconds", None)

    # Save JSON
    json_path = output_dir / f"{base_name}.json"
    with open(json_path, "w", encoding="utf-8") as f:
        json.dump(result, f, indent="\t", ensure_ascii=False)
    print(f"\n{GREEN}Wrote JSON:{RESET} {json_path}", file=sys.stderr)

    if raw_provider_payload is not None:
        raw_path = output_dir / f"{base_name}.elevenlabs.raw.json"
        with open(raw_path, "w", encoding="utf-8") as f:
            json.dump(raw_provider_payload, f, indent="\t", ensure_ascii=False)
        print(f"{GREEN}Wrote ElevenLabs raw JSON:{RESET} {raw_path}", file=sys.stderr)

    # Save Markdown
    md_path = output_dir / f"{base_name}.md"
    with open(md_path, "w", encoding="utf-8") as f:
        f.write(md_content)
    print(f"{GREEN}Wrote Markdown:{RESET} {md_path}", file=sys.stderr)

    print(f"\n{BOLD}Done!{RESET}", file=sys.stderr)


if __name__ == "__main__":
    main()
