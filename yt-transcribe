def check_deps(provider, diarize_enabled=False):
    """Verify required tools and libraries are available."""
    missing = []

    if not shutil.which("ffmpeg"):
        missing.append("ffmpeg")

    try:
        import yt_dlp  # noqa: F401
    except ImportError:
        missing.append("yt-dlp (pip install yt-dlp)")

    if provider == "faster-whisper":
        try:
            import faster_whisper  # noqa: F401
        except ImportError:
            missing.append("faster-whisper (pip install faster-whisper)")
        if diarize_enabled:
            try:
                import torch  # noqa: F401
            except ImportError:
                missing.append("torch (pip install torch)")
            try:
                from pyannote.audio import Pipeline  # noqa: F401
            except ImportError:
                missing.append("pyannote.audio (pip install pyannote.audio)")
    else:
        try:
            import elevenlabs  # noqa: F401
        except ImportError:
            missing.append("elevenlabs (pip install elevenlabs)")

    if missing:
        print(f"{RED}Missing dependencies:{RESET} {', '.join(missing)}", file=sys.stderr)
        sys.exit(1)


# ── Time range parsing ───────────────────────────────────────────────────────

def parse_time_offset(value):
    """Parse a time value (seconds, MM:SS, HH:MM:SS) into seconds."""
    text = (value or "").strip()
    if not text:
        raise argparse.ArgumentTypeError("time value cannot be empty")

    parts = text.split(":")
    if len(parts) > 3:
        raise argparse.ArgumentTypeError(
            f"invalid time value '{value}' (expected seconds, MM:SS, or HH:MM:SS)"
        )
    if any(not p for p in parts):
        raise argparse.ArgumentTypeError(
            f"invalid time value '{value}' (empty time component)"
        )

    total_seconds = 0.0
    for idx, part in enumerate(reversed(parts)):
        if not re.fullmatch(r"\d+(?:\.\d+)?", part):
            raise argparse.ArgumentTypeError(
                f"invalid time value '{value}' (must be numeric)"
            )
        if idx > 0 and "." in part:
            raise argparse.ArgumentTypeError(
                f"invalid time value '{value}' (hours/minutes must be whole numbers)"
            )
        total_seconds += float(part) * (60 ** idx)

    return total_seconds


def format_seconds_for_yt_dlp(seconds):
    """Format a seconds value as a compact string for ffmpeg args."""
    rounded = round(seconds)
    if abs(seconds - rounded) < 1e-6:
        return str(int(rounded))
    return f"{seconds:.3f}".rstrip("0").rstrip(".")


def apply_clip_download_opts(ydl_opts, start_seconds=None, end_seconds=None):
    """Configure yt-dlp to fetch only a requested time window with ffmpeg."""
    if start_seconds is None and end_seconds is None:
        return

    ffmpeg_input_args = []
    if start_seconds is not None:
        ffmpeg_input_args.extend(["-ss", format_seconds_for_yt_dlp(start_seconds)])
    if end_seconds is not None:
        ffmpeg_input_args.extend(["-to", format_seconds_for_yt_dlp(end_seconds)])

    ydl_opts["external_downloader"] = "ffmpeg"
    ydl_opts["external_downloader_args"] = {"ffmpeg_i": ffmpeg_input_args}


# ── Argument parsing ─────────────────────────────────────────────────────────

def parse_args():
    """Parse command-line arguments."""
    parser = argparse.ArgumentParser(
        description="Download and transcribe a video URL",
    )
    parser.add_argument("url", help="Video URL supported by yt-dlp")
    parser.add_argument(
        "--provider",
        choices=["faster-whisper", "elevenlabs"],
        default=DEFAULT_PROVIDER,
        help=f"Transcription backend (default: {DEFAULT_PROVIDER})",
    )
    parser.add_argument(
        "--model", default=DEFAULT_MODEL,
        help=(
            "Transcription model name "
            f"(default: {DEFAULT_MODEL}, ElevenLabs fallback default: {DEFAULT_ELEVENLABS_MODEL})"
        ),
    )
    parser.add_argument(
        "--language", default=DEFAULT_LANGUAGE,
        help=f"Language hint (default: {DEFAULT_LANGUAGE})",
    )
    parser.add_argument(
        "--vault-dir", default=DEFAULT_VAULT_DIR,
        help=f"Subdirectory inside Obsidian vault (default: {DEFAULT_VAULT_DIR})",
    )
    parser.add_argument(
        "--diarize", action="store_true",
        help=(
            "Enable speaker diarization "
            "(local: pyannote + HF token, elevenlabs: built-in diarization)"
        ),
    )
    parser.add_argument(
        "--speakers", type=int, default=None,
        help="Speaker count hint (local diarization target; ElevenLabs max speakers)",
    )
    parser.add_argument(
        "--hf-token", type=str, default=None,
        help="HuggingFace token for pyannote (or set HF_TOKEN env var)",
    )
    parser.add_argument(
        "--elevenlabs-api-key", type=str, default=None,
        help="ElevenLabs API key (or set ELEVENLABS_API_KEY env var)",
    )
    parser.add_argument(
        "--tag-audio-events", action="store_true",
        help="Tag non-speech audio events (ElevenLabs only)",
    )
    parser.add_argument(
        "--timestamps-granularity",
        choices=["none", "word", "character"],
        default="word",
        help="Timestamp detail level for ElevenLabs responses (default: word)",
    )
    parser.add_argument(
        "--keyterm",
        action="append",
        default=[],
        help="ElevenLabs keyterm bias phrase (repeat flag for multiple keyterms)",
    )
    parser.add_argument(
        "--entity-detection",
        action="append",
        default=[],
        help="ElevenLabs entity detection type (repeat flag, or comma-separated values)",
    )
    parser.add_argument(
        "--additional-format",
        action="append",
        default=[],
        choices=["docx", "html", "pdf", "segmented_json", "srt", "txt"],
        help="Ask ElevenLabs for an additional transcript export format",
    )
    parser.add_argument(
        "--use-multi-channel",
        action="store_true",
        help="Enable ElevenLabs multi-channel transcription mode",
    )
    parser.add_argument(
        "--name-speakers", action="store_true",
        help="Interactively name speakers using video frame previews (implies --diarize)",
    )
    parser.add_argument(
        "--start",
        type=parse_time_offset,
        default=None,
        help="Start offset (seconds, MM:SS, or HH:MM:SS)",
    )
    parser.add_argument(
        "--end",
        type=parse_time_offset,
        default=None,
        help="End offset (seconds, MM:SS, or HH:MM:SS)",
    )
    output_group = parser.add_mutually_exclusive_group()
    output_group.add_argument(
        "--no-vault", action="store_true",
        help="Write output to current directory instead of Obsidian vault",
    )
    output_group.add_argument(
        "--output", type=str, default=None,
        help="Explicit output directory (overrides vault)",
    )
    args = parser.parse_args()
    start_for_validation = args.start if args.start is not None else 0.0
    if args.end is not None and args.end <= start_for_validation:
        parser.error("--end must be greater than --start (or greater than 0 if --start is omitted)")
    return args


# ── YouTube metadata and download ────────────────────────────────────────────

def fetch_metadata(url):
    """Extract video metadata without downloading."""
    import yt_dlp

    print(f"{DIM}Fetching metadata...{RESET}", file=sys.stderr)

    ydl_opts = {
        "quiet": True,
        "no_warnings": True,
        "skip_download": True,
        "cookiesfrombrowser": ("chrome",),
        "ignore_no_formats_error": True,
        "js_runtimes": {"node": {}},
        "remote_components": ["ejs:github"],
    }

    with yt_dlp.YoutubeDL(ydl_opts) as ydl:
        info = ydl.extract_info(url, download=False)

    duration = info.get("duration", 0)
    hours = duration // 3600
    minutes = (duration % 3600) // 60
    seconds = duration % 60
    if hours > 0:
        duration_str = f"{hours}h{minutes:02d}m{seconds:02d}s"
    else:
        duration_str = f"{minutes}m{seconds:02d}s"

    upload_date = info.get("upload_date", "")
    if upload_date and len(upload_date) == 8:
        date_str = f"{upload_date[:4]}-{upload_date[4:6]}-{upload_date[6:8]}"
    else:
        from datetime import date
        date_str = date.today().isoformat()

    meta = {
        "title": info.get("title", "Untitled"),
        "channel": info.get("channel", info.get("uploader", "Unknown")),
        "duration": duration,
        "duration_str": duration_str,
        "date": date_str,
        "url": url,
        "id": info.get("id", ""),
    }

    print(f"  {BOLD}{meta['title']}{RESET}", file=sys.stderr)
    print(f"  {DIM}{meta['channel']} | {meta['duration_str']} | {meta['date']}{RESET}", file=sys.stderr)

    return meta


def download_audio(url, tmp_dir, start_seconds=None, end_seconds=None):
    """Download best-quality audio and return local file path."""
    import yt_dlp

    if start_seconds is not None or end_seconds is not None:
        start_label = format_ts_short(start_seconds or 0.0)
        end_label = format_ts_short(end_seconds) if end_seconds is not None else "end"
        print(f"\n{DIM}Downloading audio clip ({start_label} -> {end_label})...{RESET}", file=sys.stderr)
    else:
        print(f"\n{DIM}Downloading audio...{RESET}", file=sys.stderr)

    raw_audio = str(Path(tmp_dir) / "audio.%(ext)s")
    ydl_opts = {
        "format": "bestaudio/best",
        "outtmpl": raw_audio,
        "quiet": True,
        "no_warnings": True,
        "cookiesfrombrowser": ("chrome",),
        "js_runtimes": {"node": {}},
        "remote_components": ["ejs:github"],
    }
    apply_clip_download_opts(ydl_opts, start_seconds, end_seconds)

    with yt_dlp.YoutubeDL(ydl_opts) as ydl:
        ydl.download([url])

    # Find the downloaded file (extension varies)
    downloaded = list(Path(tmp_dir).glob("audio.*"))
    if not downloaded:
        print(f"{RED}Error: no audio file downloaded{RESET}", file=sys.stderr)
        sys.exit(1)
    return str(downloaded[0])


def convert_audio_for_faster_whisper(input_path, tmp_dir):
    """Convert source audio to 16kHz mono WAV for local faster-whisper."""
    wav_path = str(Path(tmp_dir) / "audio_16k.wav")
    print(f"{DIM}Converting to 16kHz WAV...{RESET}", file=sys.stderr)

    result = subprocess.run(
        [
            "ffmpeg", "-y", "-i", str(input_path),
            "-ar", "16000", "-ac", "1", "-c:a", "pcm_s16le",
            wav_path, "-loglevel", "error",
        ],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print(f"{RED}Error converting audio:{RESET} {result.stderr}", file=sys.stderr)
        sys.exit(1)

    return wav_path


def download_video(url, tmp_dir, start_seconds=None, end_seconds=None):
    """Download lowest-quality video stream for frame extraction."""
    import yt_dlp

    if start_seconds is not None or end_seconds is not None:
        start_label = format_ts_short(start_seconds or 0.0)
        end_label = format_ts_short(end_seconds) if end_seconds is not None else "end"
        print(
            f"\n{DIM}Downloading clipped video for speaker frames ({start_label} -> {end_label})...{RESET}",
            file=sys.stderr,
        )
    else:
        print(f"\n{DIM}Downloading video for speaker frames...{RESET}", file=sys.stderr)

    video_path = str(Path(tmp_dir) / "video.%(ext)s")
    ydl_opts = {
        "format": "worstvideo[ext=mp4]/worstvideo",
        "outtmpl": video_path,
        "quiet": True,
        "no_warnings": True,
        "cookiesfrombrowser": ("chrome",),
        "js_runtimes": {"node": {}},
        "remote_components": ["ejs:github"],
    }
    apply_clip_download_opts(ydl_opts, start_seconds, end_seconds)

